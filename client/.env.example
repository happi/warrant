# Warrant configuration
# Copy this to .env and fill in your values

# Server URL (no trailing slash)
WARRANT_URL=https://ledger.example.com

# Organization slug
WARRANT_ORG=myorg

# Project slug
WARRANT_PROJECT=myproject

# API token (from warrant-setup or admin)
WARRANT_TOKEN=cl_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Project task prefix (e.g., SF, BE, FE)
WARRANT_PREFIX=MP
