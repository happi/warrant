#!/usr/bin/env bash
set -euo pipefail

# One-time setup: register org, project, and user with the Warrant.
# Run this once per project, then share the .env with your team.

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ENV_FILE="$SCRIPT_DIR/../.env"

echo "=== Warrant Setup ==="
echo ""

# Load existing config if present
if [[ -f "$ENV_FILE" ]]; then
    source "$ENV_FILE"
    echo "Loaded existing config from .env"
fi

# Prompt for missing values
read -rp "Ledger server URL [${WARRANT_URL:-}]: " input
WARRANT_URL="${input:-${WARRANT_URL:-}}"
: "${WARRANT_URL:?Required}"

read -rp "Organization name [${WARRANT_ORG:-}]: " input
ORG_NAME="${input:-${WARRANT_ORG:-}}"
: "${ORG_NAME:?Required}"

# Slug from name
ORG_SLUG=$(echo "$ORG_NAME" | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9]/-/g' | sed 's/--*/-/g' | sed 's/^-//;s/-$//')
read -rp "Organization slug [$ORG_SLUG]: " input
ORG_SLUG="${input:-$ORG_SLUG}"

PROJECT_ONLY=false
if [[ "${1:-}" == "--project-only" ]]; then
    PROJECT_ONLY=true
fi

read -rp "Project name: " PROJECT_NAME
: "${PROJECT_NAME:?Required}"

PROJECT_SLUG=$(echo "$PROJECT_NAME" | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9]/-/g' | sed 's/--*/-/g' | sed 's/^-//;s/-$//')
read -rp "Project slug [$PROJECT_SLUG]: " input
PROJECT_SLUG="${input:-$PROJECT_SLUG}"

read -rp "Task ID prefix (e.g., SF, BE, FE): " WARRANT_PREFIX
: "${WARRANT_PREFIX:?Required}"

read -rp "Your username [$(whoami)]: " USERNAME
USERNAME="${USERNAME:-$(whoami)}"

echo ""
echo "--- Configuration ---"
echo "Server:  $WARRANT_URL"
echo "Org:     $ORG_NAME ($ORG_SLUG)"
echo "Project: $PROJECT_NAME ($PROJECT_SLUG)"
echo "Prefix:  $WARRANT_PREFIX"
echo "User:    $USERNAME"
echo ""
read -rp "Proceed? [Y/n] " confirm
if [[ "${confirm:-Y}" =~ ^[Nn] ]]; then
    echo "Aborted."
    exit 0
fi

echo ""

# Step 1: Create organization (skip if --project-only)
if [[ "$PROJECT_ONLY" != "true" ]]; then
    echo "Creating organization..."
    ORG_RESULT=$(curl -s -X POST "${WARRANT_URL}/api/v1/orgs" \
        -H "Content-Type: application/json" \
        -d "{\"name\":\"$ORG_NAME\",\"slug\":\"$ORG_SLUG\"}")

    if echo "$ORG_RESULT" | jq -e '.data.id' > /dev/null 2>&1; then
        echo "  Created org: $ORG_SLUG"
    elif echo "$ORG_RESULT" | jq -e '.error' > /dev/null 2>&1; then
        echo "  Org may already exist ($(echo "$ORG_RESULT" | jq -r '.error.message'))"
    fi
fi

# Step 2: Create project
echo "Creating project..."
PROJ_RESULT=$(curl -s -X POST "${WARRANT_URL}/api/v1/orgs/${ORG_SLUG}/projects" \
    -H "Content-Type: application/json" \
    -d "{\"name\":\"$PROJECT_NAME\",\"slug\":\"$PROJECT_SLUG\",\"prefix\":\"$WARRANT_PREFIX\"}")

if echo "$PROJ_RESULT" | jq -e '.data.id' > /dev/null 2>&1; then
    echo "  Created project: $PROJECT_SLUG (prefix: $WARRANT_PREFIX)"
else
    echo "  Project may already exist ($(echo "$PROJ_RESULT" | jq -r '.error.message // "unknown error"'))"
fi

# Step 3: Create user
echo "Creating user..."
USER_RESULT=$(curl -s -X POST "${WARRANT_URL}/api/v1/orgs/${ORG_SLUG}/users" \
    -H "Content-Type: application/json" \
    -d "{\"username\":\"$USERNAME\",\"role\":\"admin\"}")

API_TOKEN=$(echo "$USER_RESULT" | jq -r '.data.api_token // empty')

if [[ -n "$API_TOKEN" ]]; then
    echo "  Created user: $USERNAME"
    echo "  API token: $API_TOKEN"
else
    echo "  User may already exist ($(echo "$USER_RESULT" | jq -r '.error.message // "unknown error"'))"
    echo "  You'll need your existing token."
    read -rp "  Enter your API token: " API_TOKEN
fi

# Step 4: Write .env
cat > "$ENV_FILE" <<EOL
# Warrant configuration
# Generated by warrant-setup on $(date -u +%Y-%m-%dT%H:%M:%SZ)

WARRANT_URL=${WARRANT_URL}
WARRANT_ORG=${ORG_SLUG}
WARRANT_PROJECT=${PROJECT_SLUG}
WARRANT_TOKEN=${API_TOKEN}
WARRANT_PREFIX=${WARRANT_PREFIX}
EOL

echo ""
echo "=== Setup Complete ==="
echo ""
echo "Config written to: $ENV_FILE"
echo ""
echo "Next steps:"
echo "  1. source $ENV_FILE"
echo "  2. ./bin/install-hooks"
echo "  3. ./bin/warrant task create \"First task\" --intent \"Get started\""
