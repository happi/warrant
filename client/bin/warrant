#!/usr/bin/env bash
set -euo pipefail

# Warrant CLI
# Local-first: reads/writes task files in your repo.
# Server optional: only needed for ID allocation, CAS, and leases.

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Find the repo root and .warrant directory
find_warrant_dir() {
    local dir="$PWD"
    while [[ "$dir" != "/" ]]; do
        if [[ -d "$dir/.warrant/tasks" ]]; then
            echo "$dir/.warrant"
            return 0
        fi
        # Also check backlog/tasks (--backlog mode)
        if [[ -d "$dir/backlog/tasks" && -f "$dir/backlog/config.yaml" ]]; then
            echo "$dir/backlog"
            return 0
        fi
        dir="$(dirname "$dir")"
    done
    echo ""
    return 1
}

WARRANT_DIR="$(find_warrant_dir)" || true

# Load config
load_config() {
    local config_file=""
    if [[ -n "${WARRANT_DIR}" ]]; then
        if [[ -f "${WARRANT_DIR}/config.yaml" ]]; then
            config_file="${WARRANT_DIR}/config.yaml"
        elif [[ -f "${WARRANT_DIR}/config.yml" ]]; then
            config_file="${WARRANT_DIR}/config.yml"
        fi
    fi

    if [[ -n "$config_file" ]]; then
        WARRANT_PREFIX=$(grep "^prefix:" "$config_file" | sed 's/prefix: *//' | tr -d "'\"")
        # Read tasks_dir
        local td
        td=$(grep "^tasks_dir:" "$config_file" 2>/dev/null | sed 's/tasks_dir: *//' | tr -d "'\"" || true)
        if [[ -n "$td" ]]; then
            # Resolve relative to repo root
            local repo_root
            repo_root="$(dirname "$WARRANT_DIR")"
            if [[ "$td" == /* ]]; then
                TASKS_DIR="$td"
            else
                TASKS_DIR="$repo_root/$td"
            fi
        fi

        # Read filename_format
        FILENAME_FORMAT=$(grep "^filename_format:" "$config_file" 2>/dev/null | sed 's/filename_format: *//' | tr -d "'\"" || true)

        # Read completed_dir
        local cd_val
        cd_val=$(grep "^completed_dir:" "$config_file" 2>/dev/null | sed 's/completed_dir: *//' | tr -d "'\"" || true)
        if [[ -n "$cd_val" ]]; then
            local repo_root
            repo_root="$(dirname "$WARRANT_DIR")"
            if [[ "$cd_val" == /* ]]; then
                COMPLETED_DIR="$cd_val"
            else
                COMPLETED_DIR="$repo_root/$cd_val"
            fi
        fi

        # Read server config
        local url org project token_env
        url=$(grep "^  url:" "$config_file" 2>/dev/null | sed 's/  url: *//' | tr -d "'\"" || true)
        org=$(grep "^  org:" "$config_file" 2>/dev/null | sed 's/  org: *//' | tr -d "'\"" || true)
        project=$(grep "^  project:" "$config_file" 2>/dev/null | sed 's/  project: *//' | tr -d "'\"" || true)
        token_env=$(grep "^  token_env:" "$config_file" 2>/dev/null | sed 's/  token_env: *//' | tr -d "'\"" || true)
        if [[ -n "$url" ]]; then WARRANT_URL="${WARRANT_URL:-$url}"; fi
        if [[ -n "$org" ]]; then WARRANT_ORG="${WARRANT_ORG:-$org}"; fi
        if [[ -n "$project" ]]; then WARRANT_PROJECT="${WARRANT_PROJECT:-$project}"; fi
        if [[ -n "$token_env" ]]; then
            local resolved="${!token_env:-}"
            if [[ -n "$resolved" ]]; then
                WARRANT_TOKEN="${WARRANT_TOKEN:-$resolved}"
            fi
        fi
    fi

    # From .warrant/.env or backlog/.env (overrides, has token)
    if [[ -n "${WARRANT_DIR}" && -f "${WARRANT_DIR}/.env" ]]; then
        source "${WARRANT_DIR}/.env"
    fi

    # Fallback to script dir .env
    if [[ -z "${WARRANT_URL:-}" && -f "$SCRIPT_DIR/../.env" ]]; then
        source "$SCRIPT_DIR/../.env"
    fi

    WARRANT_PREFIX="${WARRANT_PREFIX:-}"
    FILENAME_FORMAT="${FILENAME_FORMAT:-id}"
    COMPLETED_DIR="${COMPLETED_DIR:-}"

    # Default tasks dir
    if [[ -z "${TASKS_DIR:-}" && -n "${WARRANT_DIR}" ]]; then
        TASKS_DIR="${WARRANT_DIR}/tasks"
    fi
}

load_config

# Server API (optional)
has_server() {
    [[ -n "${WARRANT_URL:-}" && -n "${WARRANT_TOKEN:-}" ]]
}

api() {
    local method="$1" path="$2"
    shift 2
    if ! has_server; then
        echo '{"error":"No server configured"}' >&2
        return 1
    fi
    local base="${WARRANT_URL}/api/v1/orgs/${WARRANT_ORG}/projects/${WARRANT_PROJECT}"
    curl -s -X "$method" "${base}${path}" \
        -H "Authorization: Bearer ${WARRANT_TOKEN}" \
        -H "Content-Type: application/json" \
        -H "X-Actor: $(whoami)" \
        "$@"
}

api_id() {
    if ! has_server; then
        echo "Error: Server required for ID allocation. Set WARRANT_URL in .warrant/.env" >&2
        exit 1
    fi
    curl -s -X POST "${WARRANT_URL}/api/id/next" \
        -H "Content-Type: application/json" \
        -d "{\"prefix\":\"${WARRANT_PREFIX}\"}"
}

# Local task file operations
task_file() {
    local id="$1"
    local title="${2:-}"
    case "$FILENAME_FORMAT" in
        title)
            if [[ -n "$title" ]]; then
                local slug
                slug=$(echo "$title" | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9]/-/g' | sed 's/--*/-/g' | sed 's/^-//;s/-$//' | head -c 60)
                local lower_id
                lower_id=$(echo "$id" | tr '[:upper:]' '[:lower:]')
                echo "${TASKS_DIR}/${lower_id} - ${slug}.md"
            else
                # Search for existing file by ID prefix
                local found
                found=$(find "${TASKS_DIR}" -maxdepth 1 -name "$(echo "$id" | tr '[:upper:]' '[:lower:]')*" -o -name "${id}*" 2>/dev/null | head -1)
                if [[ -n "$found" ]]; then
                    echo "$found"
                else
                    echo "${TASKS_DIR}/${id}.md"
                fi
            fi
            ;;
        *)
            echo "${TASKS_DIR}/${id}.md"
            ;;
    esac
}

read_frontmatter() {
    local file="$1" key="$2"
    if [[ ! -f "$file" ]]; then return 1; fi
    sed -n '/^---$/,/^---$/p' "$file" | grep "^${key}:" | sed "s/^${key}: *//" | tr -d "'\""
}

read_section() {
    local file="$1" heading="$2"
    if [[ ! -f "$file" ]]; then return 1; fi
    awk "/^## ${heading}\$/{found=1; next} /^## /{if(found) exit} found" "$file" | sed '/^$/d' | head -5
}

write_task_file() {
    local id="$1" title="$2" intent="$3" priority="$4" labels="$5" decision="$6"
    local file
    file="$(task_file "$id" "$title")"
    local now
    now="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
    local labels_yaml="[]"
    if [[ -n "$labels" ]]; then
        labels_yaml="[$(echo "$labels" | sed 's/,/, /g')]"
    fi

    mkdir -p "$(dirname "$file")"
    cat > "$file" << EOF
---
id: ${id}
title: "${title}"
status: open
priority: ${priority:-medium}
labels: ${labels_yaml}
created_by: $(whoami)
created_at: '${now}'
---

## Intent

${intent:-No intent specified.}
EOF

    if [[ -n "$decision" ]]; then
        cat >> "$file" << EOF

## Decision

${decision}
EOF
    fi
    echo "$file"
}

update_frontmatter() {
    local file="$1" key="$2" value="$3"
    if [[ ! -f "$file" ]]; then return 1; fi
    if grep -q "^${key}:" "$file"; then
        sed -i "s/^${key}:.*/${key}: ${value}/" "$file"
    fi
}

find_task_file() {
    local id="$1"
    local direct
    direct="$(task_file "$id")"
    if [[ -f "$direct" ]]; then
        echo "$direct"
        return 0
    fi
    # Search by ID in filename
    local found
    found=$(find "${TASKS_DIR}" -maxdepth 1 -name "${id}*" -o -name "$(echo "$id" | tr '[:upper:]' '[:lower:]')*" 2>/dev/null | head -1)
    if [[ -n "$found" ]]; then
        echo "$found"
        return 0
    fi
    echo "$direct"
    return 1
}

# Commands

cmd_task() {
    local subcmd="${1:-help}"
    shift || true

    case "$subcmd" in
        create)
            local title="${1:?Usage: warrant task create TITLE [--intent TEXT] [--priority P] [--labels l1,l2] [--decision TEXT]}"
            shift
            local intent="" priority="" labels="" decision=""
            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --intent) intent="$2"; shift 2 ;;
                    --priority) priority="$2"; shift 2 ;;
                    --labels) labels="$2"; shift 2 ;;
                    --decision) decision="$2"; shift 2 ;;
                    *) echo "Unknown option: $1" >&2; exit 1 ;;
                esac
            done

            if [[ -z "${TASKS_DIR:-}" ]]; then
                echo "Error: No tasks directory found. Run: warrant init" >&2
                exit 1
            fi

            # Allocate ID from server if available, otherwise use local counter
            local task_id
            if has_server; then
                task_id=$(api_id | python3 -c "import sys,json; print(json.load(sys.stdin)['id'])" 2>/dev/null)
            else
                # Local fallback: find highest existing number and increment
                local max=0
                for f in "${TASKS_DIR}"/*.md; do
                    [[ -f "$f" ]] || continue
                    local num
                    num=$(basename "$f" .md | grep -oE '[0-9]+' | tail -1 || echo 0)
                    if [[ "$num" -gt "$max" ]]; then max="$num"; fi
                done
                local next=$((max + 1))
                local prefix="${WARRANT_PREFIX:-W}"
                task_id="${prefix}-${next}"
            fi

            local created_file
            created_file=$(write_task_file "$task_id" "$title" "$intent" "$priority" "$labels" "$decision")
            echo "Created $created_file"
            echo ""
            echo "  $task_id: $title"
            echo ""
            echo "Next:"
            echo "  git checkout -b task/${task_id}-$(echo "$title" | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9]/-/g' | sed 's/--*/-/g' | head -c 40)"
            ;;

        get|view)
            local id="${1:?Usage: warrant task get TASK-ID}"
            local file
            file="$(find_task_file "$id")" || { echo "Task $id not found" >&2; exit 1; }
            if [[ ! -f "$file" ]]; then
                echo "Task $id not found" >&2; exit 1
            fi
            cat "$file"
            ;;

        list)
            if [[ -z "${TASKS_DIR:-}" ]]; then
                echo "No tasks directory found" >&2; exit 1
            fi
            local filter_status="" filter_label=""
            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --status) filter_status="$2"; shift 2 ;;
                    --label) filter_label="$2"; shift 2 ;;
                    *) shift ;;
                esac
            done

            for f in "${TASKS_DIR}"/*.md; do
                [[ -f "$f" ]] || continue
                local id title status priority
                id=$(read_frontmatter "$f" "id")
                title=$(read_frontmatter "$f" "title" | tr -d '"')
                status=$(read_frontmatter "$f" "status")
                priority=$(read_frontmatter "$f" "priority")

                # Apply filters
                if [[ -n "$filter_status" && "$status" != "$filter_status" ]]; then continue; fi
                if [[ -n "$filter_label" ]] && ! grep -q "$filter_label" "$f"; then continue; fi

                printf "%-8s %-14s %-8s %s\n" "$id" "$status" "$priority" "$title"
            done
            ;;

        start)
            local id="${1:?Usage: warrant task start TASK-ID}"
            local file
            file="$(find_task_file "$id")" || { echo "Task $id not found" >&2; exit 1; }
            if [[ ! -f "$file" ]]; then
                echo "Task $id not found" >&2; exit 1
            fi
            update_frontmatter "$file" "status" "in_progress"

            # Create branch from task title
            local title
            title=$(read_frontmatter "$file" "title" | tr -d '"')
            local slug
            slug=$(echo "$title" | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9]/-/g' | sed 's/--*/-/g' | sed 's/^-//;s/-$//' | head -c 40)
            local branch="task/${id}-${slug}"

            git checkout -b "$branch" 2>/dev/null && echo "Created branch: $branch" || echo "Branch $branch may already exist"
            echo "$id: open > in_progress"
            ;;

        review)
            local id="${1:?Usage: warrant task review TASK-ID}"
            local file
            file="$(find_task_file "$id")" || { echo "Task $id not found" >&2; exit 1; }
            update_frontmatter "$file" "status" "in_review"
            echo "$id: in_progress > in_review"
            ;;

        done)
            local id="${1:?Usage: warrant task done TASK-ID}"
            local file
            file="$(find_task_file "$id")" || { echo "Task $id not found" >&2; exit 1; }
            update_frontmatter "$file" "status" "done"
            echo "$id: > done"
            ;;

        block)
            local id="${1:?Usage: warrant task block TASK-ID}"
            local file
            file="$(find_task_file "$id")" || { echo "Task $id not found" >&2; exit 1; }
            update_frontmatter "$file" "status" "blocked"
            echo "$id: > blocked"
            ;;

        archive)
            local id="${1:?Usage: warrant task archive TASK-ID}"
            if [[ -z "$COMPLETED_DIR" ]]; then
                echo "Error: No completed_dir configured. Add 'completed_dir' to config.yaml" >&2
                exit 1
            fi
            local file
            file="$(find_task_file "$id")" || { echo "Task $id not found" >&2; exit 1; }
            if [[ ! -f "$file" ]]; then
                echo "Task $id not found" >&2; exit 1
            fi
            local status
            status=$(read_frontmatter "$file" "status")
            if [[ "$status" != "done" && "$status" != "cancelled" ]]; then
                echo "Warning: Task status is '$status', not 'done' or 'cancelled'." >&2
                read -rp "Archive anyway? [y/N] " confirm
                if [[ ! "$confirm" =~ ^[Yy] ]]; then exit 0; fi
            fi
            mkdir -p "$COMPLETED_DIR"
            mv "$file" "$COMPLETED_DIR/"
            echo "Archived $id to $COMPLETED_DIR/$(basename "$file")"
            ;;

        help|*)
            cat <<HELP
Usage: warrant task <command> [args]

Commands:
  create TITLE [--intent TEXT] [--priority P] [--labels l1,l2] [--decision TEXT]
  get TASK-ID
  list [--status S] [--label L]
  start TASK-ID          (open > in_progress, creates branch)
  review TASK-ID         (in_progress > in_review)
  done TASK-ID           (in_review > done)
  block TASK-ID          (any > blocked)
  archive TASK-ID        (move done/cancelled task to completed_dir)
HELP
            ;;
    esac
}

cmd_trace() {
    local id="${1:?Usage: warrant trace TASK-ID}"
    local file
    file="$(find_task_file "$id")" || { echo "Task $id not found" >&2; exit 1; }

    if [[ ! -f "$file" ]]; then
        echo "Task $id not found" >&2; exit 1
    fi

    local title status intent decision
    title=$(read_frontmatter "$file" "title" | tr -d '"')
    status=$(read_frontmatter "$file" "status")
    intent=$(read_section "$file" "Intent")
    decision=$(read_section "$file" "Decision")

    echo "$id: $title"
    echo "  Status:   $status"
    if [[ -n "$intent" ]]; then
        echo "  Intent:   $intent"
    fi
    if [[ -n "$decision" ]]; then
        echo "  Decision: $decision"
    fi
    echo ""

    # Find commits referencing this task
    echo "  Commits:"
    git log --all --oneline --grep="$id" 2>/dev/null | while read -r line; do
        echo "    $line"
    done

    # Find branches
    echo ""
    echo "  Branches:"
    git branch --all 2>/dev/null | grep -i "$id" | while read -r line; do
        echo "    $line"
    done || true

    # Audit (git log on the task file)
    echo ""
    echo "  Audit (task file history):"
    local repo_root
    repo_root="$(git rev-parse --show-toplevel 2>/dev/null)"
    if [[ -n "$repo_root" ]]; then
        local rel_path="${file#$repo_root/}"
        git log --format="    %ai  %an  %s" -- "$rel_path" 2>/dev/null
    fi
}

cmd_lease() {
    local subcmd="${1:?Usage: warrant lease <acquire|release> TASK-ID [OWNER] [TTL]}"
    local id="${2:?Usage: warrant lease $subcmd TASK-ID}"
    local owner="${3:-$(whoami)}"

    if ! has_server; then
        echo "Error: Leases require a server. Configure WARRANT_URL in .warrant/.env" >&2
        exit 1
    fi

    case "$subcmd" in
        acquire)
            local ttl="${4:-3600}"
            curl -s -X POST "${WARRANT_URL}/api/leases/acquire" \
                -H "Authorization: Bearer ${WARRANT_TOKEN}" \
                -H "Content-Type: application/json" \
                -d "{\"org\":\"${WARRANT_ORG}\",\"project\":\"${WARRANT_PROJECT}\",\"task_id\":\"$id\",\"owner\":\"$owner\",\"ttl_seconds\":$ttl}"
            echo ""
            ;;
        release)
            curl -s -X POST "${WARRANT_URL}/api/leases/release" \
                -H "Authorization: Bearer ${WARRANT_TOKEN}" \
                -H "Content-Type: application/json" \
                -d "{\"org\":\"${WARRANT_ORG}\",\"project\":\"${WARRANT_PROJECT}\",\"task_id\":\"$id\",\"owner\":\"$owner\"}"
            echo "Lease released"
            ;;
        *)
            echo "Usage: warrant lease <acquire|release> TASK-ID [OWNER] [TTL]" >&2
            exit 1
            ;;
    esac
}

cmd_init() {
    local backlog_mode=false
    local prefix=""

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --backlog) backlog_mode=true; shift ;;
            *) prefix="$1"; shift ;;
        esac
    done

    if [[ "$backlog_mode" == true ]]; then
        # Backlog mode: use backlog/ directory
        mkdir -p backlog/tasks backlog/completed

        if [[ ! -f backlog/config.yaml ]]; then
            if [[ -z "$prefix" ]]; then
                read -rp "Task ID prefix (e.g., W, AUR, ZIN): " prefix
            fi
            prefix=$(echo "$prefix" | tr '[:lower:]' '[:upper:]')

            cat > backlog/config.yaml << EOF
# Warrant configuration (backlog mode)
prefix: ${prefix}
tasks_dir: backlog/tasks
completed_dir: backlog/completed
filename_format: title
protected_branch: main

# Server (optional - enables ID allocation, CAS, leases, hash chain)
# server:
#   url: http://localhost:8090
#   org: myorg
#   project: myproject
#   token_env: WARRANT_TOKEN
EOF
            echo "Created backlog/config.yaml (prefix: $prefix, backlog mode)"
        fi

        echo "Warrant initialized in backlog mode."
        echo ""
        echo "Task files: backlog/tasks/"
        echo "Completed:  backlog/completed/"
        echo ""
        echo "Create your first task:"
        echo "  warrant task create \"First task\" --intent \"Why it matters\""
    else
        # Standard mode: use .warrant/ directory
        mkdir -p .warrant/tasks .warrant/decisions .warrant/policies

        if [[ ! -f .warrant/config.yaml ]]; then
            if [[ -z "$prefix" ]]; then
                read -rp "Task ID prefix (e.g., W, AUR, ZIN): " prefix
            fi
            prefix=$(echo "$prefix" | tr '[:lower:]' '[:upper:]')

            cat > .warrant/config.yaml << EOF
# Warrant configuration
prefix: ${prefix}
tasks_dir: .warrant/tasks
protected_branch: main

# Server (optional - enables ID allocation, CAS, leases, hash chain)
# server:
#   url: http://localhost:8090
#   org: myorg
#   project: myproject
#   token_env: WARRANT_TOKEN
EOF
            echo "Created .warrant/config.yaml (prefix: $prefix)"
        fi

        echo "Warrant initialized. Create your first task:"
        echo ""
        echo "  warrant task create \"First task\" --intent \"Why it matters\""
    fi
}

cmd_board() {
    if has_server && [[ -n "${WARRANT_ORG:-}" && -n "${WARRANT_PROJECT:-}" ]]; then
        local url="${WARRANT_URL}/board/${WARRANT_ORG}/${WARRANT_PROJECT}"
        echo "Opening board: $url"
        # Try to open in browser
        if command -v xdg-open &>/dev/null; then
            xdg-open "$url" 2>/dev/null &
        elif command -v open &>/dev/null; then
            open "$url" 2>/dev/null &
        else
            echo "Open in browser: $url"
        fi
    else
        # Terminal kanban fallback
        if [[ -z "${TASKS_DIR:-}" ]]; then
            echo "No tasks directory found" >&2; exit 1
        fi

        local statuses=("open" "in_progress" "in_review" "done" "blocked")
        for status in "${statuses[@]}"; do
            local label
            case "$status" in
                in_progress) label="IN PROGRESS" ;;
                in_review) label="IN REVIEW" ;;
                *) label=$(echo "$status" | tr '[:lower:]' '[:upper:]') ;;
            esac
            local count=0
            local items=""
            for f in "${TASKS_DIR}"/*.md; do
                [[ -f "$f" ]] || continue
                local s
                s=$(read_frontmatter "$f" "status")
                if [[ "$s" == "$status" ]]; then
                    local id title priority
                    id=$(read_frontmatter "$f" "id")
                    title=$(read_frontmatter "$f" "title" | tr -d '"')
                    priority=$(read_frontmatter "$f" "priority")
                    items+="  ${id} [${priority:-?}] ${title}\n"
                    count=$((count + 1))
                fi
            done
            echo "=== ${label} ($count) ==="
            if [[ -n "$items" ]]; then
                echo -e "$items"
            else
                echo "  (empty)"
                echo ""
            fi
        done
    fi
}

cmd_record() {
    if ! has_server; then
        echo "Error: Server required for hash chain recording. Configure server in .warrant/config.yaml" >&2
        exit 1
    fi

    # Read protected branch from config
    local protected="main"
    if [[ -n "${WARRANT_DIR:-}" ]]; then
        local config_file="${WARRANT_DIR}/config.yaml"
        [[ -f "$config_file" ]] || config_file="${WARRANT_DIR}/config.yml"
        if [[ -f "$config_file" ]]; then
            local conf_branch
            conf_branch=$(grep "^protected_branch:" "$config_file" 2>/dev/null | sed 's/protected_branch: *//' | tr -d "'\"" || true)
            if [[ -n "$conf_branch" ]]; then protected="$conf_branch"; fi
        fi
    fi

    local current_branch
    current_branch=$(git rev-parse --abbrev-ref HEAD 2>/dev/null)
    if [[ "$current_branch" != "$protected" ]]; then
        echo "You are on '$current_branch', not '$protected'." >&2
        echo "The hash chain records commits on the protected branch ($protected)." >&2
        read -rp "Record from '$current_branch' anyway? [y/N] " confirm
        if [[ ! "$confirm" =~ ^[Yy] ]]; then exit 0; fi
    fi

    local count="${1:-10}"
    local range="HEAD~${count}..HEAD"

    echo "Recording commits to hash chain (branch: $current_branch)..."
    local recorded=0
    while IFS='|' read -r sha parent_sha timestamp author summary; do
        [[ -z "$sha" ]] && continue
        local result
        result=$(curl -s -X POST "${WARRANT_URL}/api/ledger/record" \
            -H "Authorization: Bearer ${WARRANT_TOKEN}" \
            -H "Content-Type: application/json" \
            -d "{
                \"org\": \"${WARRANT_ORG}\",
                \"project\": \"${WARRANT_PROJECT}\",
                \"commit_sha\": \"${sha}\",
                \"parent_sha\": \"${parent_sha}\",
                \"summary\": $(echo "$summary" | python3 -c 'import sys,json; print(json.dumps(sys.stdin.read().strip()))'),
                \"actor\": \"${author}\",
                \"timestamp\": \"${timestamp}\"
            }")
        local seq
        seq=$(echo "$result" | python3 -c "import sys,json; print(json.load(sys.stdin).get('data',{}).get('seq','?'))" 2>/dev/null)
        echo "  #${seq} ${sha:0:8} ${summary:0:60}"
        recorded=$((recorded + 1))
    done < <(git log --reverse --format="%H|%P|%aI|%an|%s" "$range" 2>/dev/null)

    echo ""
    echo "Recorded $recorded commit(s)"
}

cmd_verify() {
    if ! has_server; then
        echo "Error: Server required for verification. Configure server in .warrant/config.yaml" >&2
        exit 1
    fi

    echo "Verifying hash chain for ${WARRANT_ORG}/${WARRANT_PROJECT}..."
    echo ""

    # 1. Check server chain integrity
    local server_result
    server_result=$(curl -s "${WARRANT_URL}/api/ledger/verify/${WARRANT_ORG}/${WARRANT_PROJECT}" \
        -H "Authorization: Bearer ${WARRANT_TOKEN}")
    local valid length
    valid=$(echo "$server_result" | python3 -c "import sys,json; print(json.load(sys.stdin)['data']['valid'])" 2>/dev/null)
    length=$(echo "$server_result" | python3 -c "import sys,json; print(json.load(sys.stdin)['data']['length'])" 2>/dev/null)

    if [[ "$valid" == "True" ]]; then
        echo "Server chain: VALID ($length entries)"
    else
        local break_at
        break_at=$(echo "$server_result" | python3 -c "import sys,json; print(json.load(sys.stdin)['data'].get('break_at','?'))" 2>/dev/null)
        echo "Server chain: BROKEN at entry #$break_at"
        exit 1
    fi

    # 2. Check that every commit in the server chain exists in git history
    echo ""
    echo "Checking commits against local git history..."
    local chain
    chain=$(curl -s "${WARRANT_URL}/api/ledger/chain/${WARRANT_ORG}/${WARRANT_PROJECT}" \
        -H "Authorization: Bearer ${WARRANT_TOKEN}")

    local missing=0 found=0 rewritten=0
    echo "$chain" | python3 -c "
import sys, json
for entry in json.load(sys.stdin).get('data', []):
    print(entry['commit_sha'] + '|' + entry.get('summary',''))
" 2>/dev/null | while IFS='|' read -r sha summary; do
        if git rev-parse --verify "$sha" >/dev/null 2>&1; then
            # Commit exists. Check that the message matches.
            local actual_summary
            actual_summary=$(git log --format="%s" -1 "$sha" 2>/dev/null)
            if [[ "$actual_summary" != "$summary" ]]; then
                echo "  MISMATCH ${sha:0:8}: server=\"$summary\" git=\"$actual_summary\""
                rewritten=$((rewritten + 1))
            else
                found=$((found + 1))
            fi
        else
            echo "  MISSING  ${sha:0:8}: $summary"
            echo "           This commit was recorded but is not in git history."
            echo "           Possible force-push or rebase after recording."
            missing=$((missing + 1))
        fi
    done

    echo ""

    # 3. Check for unrecorded commits (in git but not in server chain)
    echo "Checking for unrecorded commits..."
    local all_shas
    all_shas=$(echo "$chain" | python3 -c "
import sys, json
for e in json.load(sys.stdin).get('data',[]): print(e['commit_sha'])
" 2>/dev/null)

    local unrecorded=0
    git log --format="%H" HEAD~50..HEAD 2>/dev/null | while read -r sha; do
        if ! echo "$all_shas" | grep -q "$sha"; then
            local summary
            summary=$(git log --format="%s" -1 "$sha")
            echo "  UNRECORDED ${sha:0:8}: $summary"
            unrecorded=$((unrecorded + 1))
        fi
    done

    echo ""
    echo "Verification complete."
    echo "  Run 'warrant record' to record any missing commits."
}

cmd_setup_github() {
    local workflow_dir=".github/workflows"
    local workflow_file="${workflow_dir}/warrant.yml"

    if [[ -f "$workflow_file" ]]; then
        echo "Workflow already exists at $workflow_file"
        read -rp "Overwrite? [y/N] " confirm
        if [[ ! "$confirm" =~ ^[Yy] ]]; then exit 0; fi
    fi

    mkdir -p "$workflow_dir"
    cp "${SCRIPT_DIR}/../ci/warrant-check.yml" "$workflow_file"

    echo "Created $workflow_file"
    echo ""
    echo "Next steps:"
    echo "  1. Add WARRANT_TOKEN secret in GitHub repo settings"
    echo "     Settings > Secrets and variables > Actions > New repository secret"
    echo "  2. Commit and push the workflow file"
    echo "  3. Open a PR to test"
}

cmd_setup_webhook() {
    if ! has_server; then
        echo "Error: Server required. Configure WARRANT_URL in config." >&2
        exit 1
    fi

    local repo_url=""
    if command -v gh &>/dev/null; then
        repo_url=$(gh repo view --json url -q '.url' 2>/dev/null || true)
    fi
    if [[ -z "$repo_url" ]]; then
        read -rp "GitHub repository URL (e.g., https://github.com/org/repo): " repo_url
    fi

    local result
    result=$(curl -s -X POST "${WARRANT_URL}/admin/orgs/${WARRANT_ORG}/projects/${WARRANT_PROJECT}/webhook" \
        -H "Authorization: Bearer ${WARRANT_TOKEN}" \
        -H "Content-Type: application/json" \
        -d "{\"repo_url\": \"$repo_url\"}")

    echo "Webhook configured."
    echo ""
    echo "Add this webhook in GitHub repo settings:"
    echo "  Settings > Webhooks > Add webhook"
    echo ""
    echo "  Payload URL: ${WARRANT_URL}/webhooks/github"
    echo "  Content type: application/json"
    echo "  Events: Pull requests, Pushes"
    echo ""
    echo "  The webhook secret was generated. Check the server admin UI for the secret."
}

cmd_release_notes() {
    local since_tag="" output_file=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --since) since_tag="$2"; shift 2 ;;
            --output|-o) output_file="$2"; shift 2 ;;
            *) echo "Unknown option: $1" >&2; exit 1 ;;
        esac
    done

    if [[ -z "${TASKS_DIR:-}" ]]; then
        echo "Error: No tasks directory found. Run: warrant init" >&2
        exit 1
    fi

    # Find the tag to diff from
    if [[ -z "$since_tag" ]]; then
        since_tag=$(git tag --sort=-version:refname | head -1)
        if [[ -z "$since_tag" ]]; then
            echo "Error: No git tags found. Use --since TAG to specify a starting point." >&2
            exit 1
        fi
    fi

    if ! git rev-parse "$since_tag" >/dev/null 2>&1; then
        echo "Error: Tag '$since_tag' not found" >&2
        exit 1
    fi

    local prefix="${WARRANT_PREFIX:-W}"
    local tag_date
    tag_date=$(git log -1 --format="%ai" "$since_tag" 2>/dev/null | cut -d' ' -f1)

    # Collect all warrant IDs from commits since the tag
    local -A seen_ids
    while IFS= read -r line; do
        # Extract task IDs (PREFIX-NNN) from commit subjects
        while [[ "$line" =~ ${prefix}-([0-9]+) ]]; do
            seen_ids["${prefix}-${BASH_REMATCH[1]}"]=1
            line="${line#*${BASH_REMATCH[0]}}"
        done
    done < <(git log --format="%s" "${since_tag}..HEAD" 2>/dev/null)

    if [[ ${#seen_ids[@]} -eq 0 ]]; then
        echo "No warrant references found in commits since $since_tag" >&2
        exit 0
    fi

    # Also scan completed dir
    local all_task_dirs=("$TASKS_DIR")
    if [[ -n "${COMPLETED_DIR:-}" && -d "$COMPLETED_DIR" ]]; then
        all_task_dirs+=("$COMPLETED_DIR")
    fi

    # Read task data for each referenced ID
    local -a done_tasks=()
    local -a other_tasks=()
    for id in "${!seen_ids[@]}"; do
        local file=""
        for dir in "${all_task_dirs[@]}"; do
            # Try exact match first
            if [[ -f "$dir/${id}.md" ]]; then
                file="$dir/${id}.md"
                break
            fi
            # Try case-insensitive / title-format search
            local found
            found=$(find "$dir" -maxdepth 1 \( -name "${id}*" -o -name "$(echo "$id" | tr '[:upper:]' '[:lower:]')*" \) 2>/dev/null | head -1)
            if [[ -n "$found" ]]; then
                file="$found"
                break
            fi
        done

        if [[ -z "$file" || ! -f "$file" ]]; then
            other_tasks+=("- **${id}**: _(task file not found)_")
            continue
        fi

        local title status priority labels intent
        title=$(read_frontmatter "$file" "title" | tr -d '"')
        status=$(read_frontmatter "$file" "status")
        priority=$(read_frontmatter "$file" "priority")
        labels=$(sed -n '/^---$/,/^---$/p' "$file" | grep "^labels:" | sed 's/^labels: *\[//;s/\] *$//' | tr -d "'" | tr -d '"')
        intent=$(read_section "$file" "Intent" | head -1)

        local entry="- **${id}**: ${title}"
        if [[ -n "$intent" ]]; then
            entry+=$'\n'"  _${intent}_"
        fi

        if [[ "$status" == "done" ]]; then
            done_tasks+=("$entry")
        else
            other_tasks+=("${entry} _(${status})_")
        fi
    done

    # Count commits
    local commit_count
    commit_count=$(git rev-list --count "${since_tag}..HEAD" 2>/dev/null)

    # Build the release notes
    local next_version
    next_version=$(git describe --tags --always HEAD 2>/dev/null || echo "unreleased")

    local notes=""
    notes+="# Release Notes"$'\n'
    notes+=$'\n'
    notes+="**Since:** ${since_tag} (${tag_date})"$'\n'
    notes+="**Commits:** ${commit_count}"$'\n'
    notes+="**Warrants completed:** ${#done_tasks[@]}"$'\n'
    notes+=$'\n'

    if [[ ${#done_tasks[@]} -gt 0 ]]; then
        notes+="## Completed"$'\n'
        notes+=$'\n'
        for entry in "${done_tasks[@]}"; do
            notes+="${entry}"$'\n'
        done
        notes+=$'\n'
    fi

    if [[ ${#other_tasks[@]} -gt 0 ]]; then
        notes+="## In Progress"$'\n'
        notes+=$'\n'
        for entry in "${other_tasks[@]}"; do
            notes+="${entry}"$'\n'
        done
        notes+=$'\n'
    fi

    # Append commit log summary
    notes+="## Commits"$'\n'
    notes+=$'\n'
    while IFS= read -r line; do
        notes+="- ${line}"$'\n'
    done < <(git log --format="%h %s" "${since_tag}..HEAD" 2>/dev/null)

    if [[ -n "$output_file" ]]; then
        echo "$notes" > "$output_file"
        echo "Release notes written to $output_file"
    else
        echo "$notes"
    fi
}

cmd_why() {
    local ref="${1:-HEAD}"

    # Resolve to full SHA
    local sha
    sha=$(git rev-parse "$ref" 2>/dev/null) || {
        echo "Error: Cannot resolve '$ref' to a commit" >&2
        exit 1
    }
    local short_sha="${sha:0:8}"

    # Get commit info
    local subject author date
    subject=$(git log --format="%s" -1 "$sha" 2>/dev/null)
    author=$(git log --format="%an" -1 "$sha" 2>/dev/null)
    date=$(git log --format="%ai" -1 "$sha" 2>/dev/null | cut -d' ' -f1)

    # Extract task ID from commit message
    local prefix="${WARRANT_PREFIX:-W}"
    local task_id=""
    if [[ "$subject" =~ (${prefix}-[0-9]+) ]]; then
        task_id="${BASH_REMATCH[1]}"
    fi

    echo "${short_sha} ${subject}"
    echo "  Author: ${author}"
    echo "  Date:   ${date}"

    if [[ -z "$task_id" ]]; then
        echo ""
        echo "  No warrant found in commit message."
        exit 0
    fi

    echo "  Task:   ${task_id}"

    # Find and read the task file
    local file=""
    if [[ -n "${TASKS_DIR:-}" ]]; then
        file=$(find_task_file "$task_id" 2>/dev/null) || true
    fi
    # Also check completed dir
    if [[ -z "$file" || ! -f "$file" ]] && [[ -n "${COMPLETED_DIR:-}" && -d "$COMPLETED_DIR" ]]; then
        local found
        found=$(find "$COMPLETED_DIR" -maxdepth 1 \( -name "${task_id}*" -o -name "$(echo "$task_id" | tr '[:upper:]' '[:lower:]')*" \) 2>/dev/null | head -1)
        if [[ -n "$found" ]]; then file="$found"; fi
    fi

    if [[ -z "$file" || ! -f "$file" ]]; then
        echo ""
        echo "  Task file not found for ${task_id}."
        exit 0
    fi

    local title status intent decision
    title=$(read_frontmatter "$file" "title" | tr -d '"')
    status=$(read_frontmatter "$file" "status")
    intent=$(read_section "$file" "Intent")
    decision=$(read_section "$file" "Decision")

    echo ""
    echo "  ${task_id}: ${title}"
    if [[ -n "$intent" ]]; then
        echo ""
        echo "  Intent:"
        while IFS= read -r line; do
            echo "    ${line}"
        done <<< "$intent"
    fi
    if [[ -n "$decision" ]]; then
        echo ""
        echo "  Decision:"
        while IFS= read -r line; do
            echo "    ${line}"
        done <<< "$decision"
    fi
}

cmd_check() {
    local range="${1:-}"
    if [[ -z "$range" ]]; then
        local count
        count=$(git rev-list --count HEAD 2>/dev/null || echo 0)
        if [[ "$count" -le 20 ]]; then
            range="HEAD"
        else
            range="HEAD~20..HEAD"
        fi
    fi
    local prefix="${WARRANT_PREFIX:-W}"
    local missing=0 total=0

    while IFS='|' read -r sha subject; do
        [[ -z "$sha" ]] && continue
        total=$((total + 1))
        if ! [[ "$subject" =~ ${prefix}-[0-9]+ ]]; then
            echo "  MISSING  ${sha:0:8} ${subject}"
            missing=$((missing + 1))
        fi
    done < <(git log --format="%H|%s" "$range" 2>/dev/null)

    if [[ "$missing" -eq 0 ]]; then
        echo "All $total commits have warrants."
    else
        echo ""
        echo "$missing of $total commits missing a warrant reference."
    fi
}

# Main dispatch
case "${1:-help}" in
    task)    shift; cmd_task "$@" ;;
    why)     shift; cmd_why "$@" ;;
    check)   shift; cmd_check "$@" ;;
    trace)   shift; cmd_trace "$@" ;;
    lease)   shift; cmd_lease "$@" ;;
    record)  shift; cmd_record "$@" ;;
    verify)  shift; cmd_verify "$@" ;;
    init)    shift; cmd_init "$@" ;;
    board)   shift; cmd_board "$@" ;;
    setup-github)  shift; cmd_setup_github "$@" ;;
    setup-webhook) shift; cmd_setup_webhook "$@" ;;
    release-notes) shift; cmd_release_notes "$@" ;;
    help|--help|-h)
        cat <<HELP
Warrant CLI - every change needs a warrant.

Usage: warrant <command> [args]

Commands:
  init [--backlog] [PREFIX]  Initialize warrant in the current repo
  task                       Create, view, list, and transition tasks
  why [COMMIT]               Given a commit, show why it exists
  check [RANGE]              Find commits missing a warrant reference
  trace TASK-ID              Show full traceability for a task
  board                      Open Kanban board (browser or terminal)
  lease                      Acquire or release a task lease (requires server)
  record [N]                 Record last N commits to compliance hash chain (default: 10)
  verify                     Verify repo integrity against server hash chain
  release-notes              Generate release notes from warrants since last tag
  setup-github               Install GitHub Actions workflow for PR checks
  setup-webhook              Configure GitHub webhook on the server

Options:
  init --backlog             Use backlog/ directory (title-based filenames, completed dir)

Examples:
  warrant init
  warrant init --backlog
  warrant task create "Fix login bug" --intent "Users can't log in" --priority high
  warrant task start W-1
  warrant task archive W-1
  warrant why abc123          # why does this commit exist?
  warrant why HEAD~3          # works with any git ref
  warrant check               # find commits without warrants
  warrant trace W-1
  warrant board
  warrant record              # record recent commits to hash chain
  warrant verify              # check repo matches server chain
  warrant release-notes        # release notes from warrants since last tag
  warrant release-notes --since v0.1.0 -o RELEASE.md
  warrant setup-github        # install GitHub Actions workflow
HELP
        ;;
    *)
        echo "Unknown command: $1 (try: warrant help)" >&2
        exit 1
        ;;
esac
