#!/usr/bin/env bash

# Warrant post-push hook
# Records commits to the compliance hash chain on the server,
# but ONLY when pushing to the protected branch (default: main).
#
# Install: install-hooks (or manually copy to .git/hooks/post-push)
# Note: git has no native post-push hook. This is called by
# wrapping git push or invoked manually after push.

set -euo pipefail

# Find .warrant dir
find_warrant_dir() {
    local dir="$PWD"
    while [[ "$dir" != "/" ]]; do
        if [[ -d "$dir/.warrant" ]]; then echo "$dir/.warrant"; return 0; fi
        dir="$(dirname "$dir")"
    done
    return 1
}

WARRANT_DIR="$(find_warrant_dir 2>/dev/null)" || exit 0

# Load config
if [[ -f "${WARRANT_DIR}/.env" ]]; then
    source "${WARRANT_DIR}/.env"
fi

# Need server to record
if [[ -z "${WARRANT_URL:-}" || -z "${WARRANT_TOKEN:-}" ]]; then
    exit 0
fi

ORG="${WARRANT_ORG:-}"
PROJECT="${WARRANT_PROJECT:-}"
if [[ -z "$ORG" || -z "$PROJECT" ]]; then
    exit 0
fi

# Read protected branch from config (default: main)
PROTECTED="main"
if [[ -f "${WARRANT_DIR}/config.yaml" ]]; then
    CONF_BRANCH=$(grep "^protected_branch:" "${WARRANT_DIR}/config.yaml" 2>/dev/null | sed 's/protected_branch: *//' | tr -d "'\""  || true)
    if [[ -n "$CONF_BRANCH" ]]; then
        PROTECTED="$CONF_BRANCH"
    fi
fi

# Check current branch
CURRENT_BRANCH=$(git rev-parse --abbrev-ref HEAD 2>/dev/null)
if [[ "$CURRENT_BRANCH" != "$PROTECTED" ]]; then
    exit 0
fi

# Get the latest commit the server knows about for this project
LAST_SERVER_SHA=$(curl -s "${WARRANT_URL}/api/ledger/chain/${ORG}/${PROJECT}?limit=100" \
    -H "Authorization: Bearer ${WARRANT_TOKEN}" 2>/dev/null \
    | python3 -c "
import sys,json
try:
    data = json.load(sys.stdin).get('data',[])
    if data:
        last = max(data, key=lambda x: x['seq'])
        print(last['commit_sha'])
except: pass
" 2>/dev/null)

# Determine range to record
if [[ -n "$LAST_SERVER_SHA" ]] && git rev-parse --verify "$LAST_SERVER_SHA" >/dev/null 2>&1; then
    RANGE="${LAST_SERVER_SHA}..HEAD"
else
    RANGE="HEAD~20..HEAD"
fi

# Record each commit (oldest first)
RECORDED=0
while IFS='|' read -r sha parent_sha timestamp author summary; do
    [[ -z "$sha" ]] && continue

    curl -s -X POST "${WARRANT_URL}/api/ledger/record" \
        -H "Authorization: Bearer ${WARRANT_TOKEN}" \
        -H "Content-Type: application/json" \
        -d "{
            \"org\": \"${ORG}\",
            \"project\": \"${PROJECT}\",
            \"commit_sha\": \"${sha}\",
            \"parent_sha\": \"${parent_sha}\",
            \"summary\": $(echo "$summary" | python3 -c 'import sys,json; print(json.dumps(sys.stdin.read().strip()))'),
            \"actor\": \"${author}\",
            \"timestamp\": \"${timestamp}\"
        }" > /dev/null 2>&1

    RECORDED=$((RECORDED + 1))
done < <(git log --reverse --format="%H|%P|%aI|%an|%s" "$RANGE" 2>/dev/null | head -50)

if [[ $RECORDED -gt 0 ]]; then
    echo "warrant: recorded $RECORDED commit(s) to hash chain (branch: $PROTECTED)"
fi
