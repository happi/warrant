#!/usr/bin/env bash

# Change Ledger pre-push hook
# Warns about commits without task IDs in the push range.
# This is a warning only — it does not block the push.

PATTERN='[A-Z]{1,10}-[0-9]+'

WARN_COUNT=0

while read -r local_ref local_sha remote_ref remote_sha; do
    if [[ "$remote_sha" == "0000000000000000000000000000000000000000" ]]; then
        # New branch — check all commits
        RANGE="$local_sha"
    else
        RANGE="${remote_sha}..${local_sha}"
    fi

    while IFS= read -r line; do
        SHA=$(echo "$line" | cut -d' ' -f1)
        MSG=$(echo "$line" | cut -d' ' -f2-)
        if [[ ! "$MSG" =~ $PATTERN ]]; then
            if [[ $WARN_COUNT -eq 0 ]]; then
                echo "" >&2
                echo "WARNING: The following commits have no task ID:" >&2
            fi
            echo "  ${SHA:0:8} $MSG" >&2
            WARN_COUNT=$((WARN_COUNT + 1))
        fi
    done < <(git log --format="%H %s" --no-merges "$RANGE" 2>/dev/null)
done

if [[ $WARN_COUNT -gt 0 ]]; then
    echo "" >&2
    echo "  $WARN_COUNT commit(s) without task IDs. Consider amending." >&2
    echo "" >&2
fi

# Always allow push (warning only)
exit 0
