{erl_opts, [debug_info]}.
{deps, [
    {cowboy, "2.12.0"},
    {jsx, "3.1.0"},
    {esqlite, "0.8.8"}
]}.

{relx, [
    {release, {backlog_server, "0.1.0"}, [backlog_server, sasl]},
    {mode, prod},
    {extended_start_script, true}
]}.

{profiles, [
    {prod, [
        {relx, [{mode, prod}]}
    ]}
]}.
